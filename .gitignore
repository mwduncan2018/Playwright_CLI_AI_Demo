# Dependency directories
node_modules/
jspm_packages/

# Playwright State & Cache
# We ignore the entire playwright/ and .playwright/ directories 
# because they contain heavy browser binaries and local state.
playwright/
.playwright/
.playwright-cli/
.playwright-auth/
test-results/
playwright-report/
blob-report/

# AI & Tooling state
.claude/
.gemini/
.anthropic/

# Test Artifacts
# These are generated during runs and should not be versioned.
videos/
screenshots/
traces/

# Environment and Secrets
# Storing credentials here is common for local sites on Port 3000.
.env
.env.local
.env.*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System Files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?